NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:3000

# Development-এ খালি রাখলে API boot হবে, /api/health db: disconnected দেখাবে।
# Production-এ অবশ্যই real Atlas URI দিতে হবে।
MONGODB_URI=

# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Phase 5 AI providers
GEMINI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=
AI_PROVIDER_ORDER=gemini,groq,ollama

# Phase 5: AI model names (env থেকে — hardcode নয়, কারণ নাম দ্রুত বদলায়)
GEMINI_MODEL=gemini-2.5-flash-lite
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_MODEL=llama3
AI_USER_RPM=15

# Seed script — প্রথম admin bootstrap (npm run seed)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin
